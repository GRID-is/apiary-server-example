{
  "name": "apiary-server-example",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--experimental-wasm-modules --max-old-space-size=8192\" tsx watch src/index.ts",
    "start": "NODE_OPTIONS=--experimental-wasm-modules node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-wasm-modules vitest run",
    "test:watch": "NODE_OPTIONS=--experimental-wasm-modules vitest"
  },
  "dependencies": {
    "@borgar/xlsx-convert": "^3.6.3",
    "@grid-is/apiary": "^15.1.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^1.2.2",
    "hono": "^4.6.0",
    "uuid": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.16"
  }
}
